<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Studená sekce — příprava | ŠPORK</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #F5F3EE;
    --surface: #FFFFFF;
    --border: rgba(0,0,0,0.10);
    --border-strong: rgba(0,0,0,0.18);
    --text-primary: #1A1A18;
    --text-secondary: #6B6A65;
    --text-muted: #A8A79F;
    --accent: #2A5C3F;
    --accent-light: #E8F0EB;
    --accent-mid: #C2D8C9;
    --done-text: #A8A79F;
    --tag-bg: #F0EDE6;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
    padding: 2rem 1rem 4rem;
  }

  .page-header {
    max-width: 680px;
    margin: 0 auto 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .logo {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .page-title {
    font-size: 26px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.15;
  }

  .page-sub {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .header-right { text-align: right; }

  .global-reset {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    padding: 6px 14px;
    cursor: pointer;
    transition: all 0.15s;
    text-transform: uppercase;
  }
  .global-reset:hover { background: var(--surface); color: var(--text-primary); }

  .global-stats {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  .container {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    padding: 6px 0 4px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .card:hover { border-color: var(--border-strong); }
  .card.complete { border-color: var(--accent-mid); }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 16px 10px;
    cursor: pointer;
    user-select: none;
  }

  .card-header-left { flex: 1; min-width: 0; }

  .dish-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .dish-meta {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 3px;
    letter-spacing: 0.03em;
  }

  .card-header-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .progress-pill {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 20px;
    background: var(--tag-bg);
    color: var(--text-secondary);
    transition: all 0.2s;
  }
  .progress-pill.done-all {
    background: var(--accent-light);
    color: var(--accent);
  }

  .chevron {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .card.open .chevron { transform: rotate(180deg); }

  .progress-bar {
    height: 2px;
    background: var(--border);
    margin: 0 16px;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 1px;
    transition: width 0.25s ease;
  }

  .card-body {
    padding: 12px 16px 14px;
    display: none;
  }
  .card.open .card-body { display: block; }

  .ingredients {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 12px;
  }

  .ing-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
  }
  .ing-row:last-child { border-bottom: none; }

  .checkbox {
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--border-strong);
    border-radius: 5px;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    background: var(--surface);
  }
  .checkbox:hover { border-color: var(--accent); }
  .checkbox.checked {
    background: var(--accent);
    border-color: var(--accent);
  }
  .checkbox.checked::after {
    content: '';
    display: block;
    width: 9px;
    height: 6px;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
  }

  .ing-label {
    font-size: 14px;
    color: var(--text-primary);
    cursor: pointer;
    flex: 1;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .ing-label.done {
    text-decoration: line-through;
    color: var(--done-text);
  }

  .footer-row {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 4px;
  }

  .comment-input {
    flex: 1;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--text-primary);
    background: var(--tag-bg);
    border: 1px solid transparent;
    border-radius: 7px;
    padding: 7px 10px;
    resize: none;
    outline: none;
    min-height: 34px;
    transition: border-color 0.15s;
    line-height: 1.4;
  }
  .comment-input:focus { border-color: var(--border-strong); background: var(--surface); }
  .comment-input::placeholder { color: var(--text-muted); }

  .reset-btn {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 7px 10px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .reset-btn:hover { border-color: var(--border-strong); color: var(--text-secondary); }

  .ing-en {
    font-size: 12px;
    color: var(--text-muted);
    font-style: italic;
  }

  .ing-label.done .ing-en { color: var(--done-text); }
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 2.5rem;
    letter-spacing: 0.06em;
  }

  @media (max-width: 480px) {
    body { padding: 1.2rem 0.75rem 3rem; }
    .page-title { font-size: 22px; }
  }
</style>
</head>
<body>

<div class="page-header">
  <div>
    <div class="logo">Restaurace ŠPORK</div>
    <div class="page-title">Studená sekce</div>
    <div class="page-sub">Příprava ingrediencí · Cold section prep</div>
  </div>
  <div class="header-right">
    <button class="global-reset" onclick="resetAll()">Resetovat vše · Reset all</button>
    <div class="global-stats" id="global-stats">0 / 0 ingrediencí</div>
  </div>
</div>

<div class="container" id="app"></div>
<div class="timestamp" id="timestamp"></div>

<script>
const menu = [
  {
    section: 'Salát · Salad',
    dishes: [
      {
        id: 'gocar',
        name: 'Salát Gočár',
        meta: 'velikost S / L',
        ingredients: [
          'Dubový salát (oak leaf lettuce)',
          'Bílý chřest (white asparagus)',
          'Vejce na hniličku (soft-boiled egg)',
          'Dresink z podmáslí (buttermilk dressing)',
          'Grana Moravia',
          'Pesto z jarní cibulky (spring onion pesto)',
          'Lískové ořechy (hazelnuts)'
        ]
      },
      {
        id: 'bonrepos',
        name: 'Salát Bon Repos',
        meta: 'velikost S / L',
        ingredients: [
          'Burrata',
          'Chlebový garum (bread garum)',
          'Mladý špenát (baby spinach)',
          'Kedlubna (kohlrabi)',
          'Ředkvička (radish)',
          'Ředkev Daikon (daikon radish)',
          'Císařský hrášek (snap peas)',
          'Jahody (strawberries)',
          'Mátový dresink s limetkou (mint & lime dressing)',
          'Výhonky (sprouts)'
        ]
      },
      {
        id: 'bram_salat',
        name: 'Bramborový salát',
        meta: 'příloha / side',
        ingredients: [
          'Bramborový salát (potato salad)',
          'Řapík (celery stalk)',
          'Ředkvičky julienne (radish julienne)',
          'Jablka kostky (apple cubes)'
        ]
      },
      {
        id: 'okur_salat',
        name: 'Okurkový salát',
        meta: 'příloha / side',
        ingredients: [
          'Okurky (cucumbers)',
          'Koprkový dresink (dill dressing)',
          'Koprkový olej (dill oil)',
          'Kopr (dill)',
          'Jogurt (yogurt)'
        ]
      }
    ]
  },
  {
    section: 'Studené předkrmy · Cold starters',
    dishes: [
      {
        id: 'spork',
        name: 'Studené předkrmové prkénko ŠPORK',
        meta: 'pro 2 osoby',
        ingredients: [
          'Husí paštika (goose pâté)',
          'Ovocný chléb s ořechy (fruit & nut bread)',
          'Ředkvička (radish)',
          'Kváskový chléb s pažitkou (sourdough with chives)'
        ]
      },
      {
        id: 'tatarak',
        name: 'Hovězí tatarák',
        meta: '150g',
        ingredients: [
          'Žloutkový gel (egg yolk gel)',
          'Cibule (onion)',
          'Cibulky (spring onions)',
          'Hořčičná semínka (mustard seeds)',
          'Majonéza z černého česneku (black garlic mayo)',
          'Červený pepř (red pepper)',
          'Zelený pepř (green pepper)',
          'Marináda na tatarák (tartare marinade)'
        ]
      },
      {
        id: 'susena',
        name: 'Sušená masa z rodinného řeznictví Čejka',
        meta: '160g',
        ingredients: [
          'Vepřový bok (pork belly)',
          'Hovězí roštěnec (beef sirloin)',
          'Vepřová šunka (pork ham)',
          'Hovězí klobása se zeleným pepřem (beef sausage, green pepper)',
          'Nakládaná zelenina (pickled vegetables)',
          'Remouládová omáčka (remoulade sauce)'
        ]
      },
      {
        id: 'pastika',
        name: 'Naše paštika',
        meta: '100g',
        ingredients: [
          'Paštika (pâté)',
          'Ovocný chléb s ořechy (fruit & nut bread)',
          'Červený rybíz s tymiánem (red currant with thyme)'
        ]
      }
    ]
  },
  {
    section: 'Vegetariánské · Vegetarian',
    dishes: [
      {
        id: 'tenderloin',
        name: 'Trhaný veganský tenderloin v barbeque omáčce',
        meta: '80g · vegan',
        ingredients: [
          'Veganská BBQ omáčka (vegan BBQ sauce)',
          'Tenderloin vege'
        ]
      },
      {
        id: 'krekry',
        name: 'Chlebové krekry',
        meta: '140g · vegan',
        ingredients: [
          'Krekry (crackers)',
          'Dýňový hummus s jogurtem a tahini — 100g (pumpkin hummus, yogurt, tahini)',
          'Sýrový dip — 100g (cheese dip)',
          'Smažená cizrna na dýňový hummus (fried chickpeas for pumpkin hummus)'
        ]
      }
    ]
  },
  {
    section: 'Sýry · Cheese',
    dishes: [
      {
        id: 'syr_biofarma',
        name: 'Sýry z Biofarmy Krasolesí',
        meta: 'pro 2 osoby | 150g',
        ingredients: [
          'Plísňový kravský sýr v popelu (ash-ripened cow blue cheese)',
          'Vyzrálý kravský horský sýr (aged mountain cow cheese)',
          'Sýr Rys',
          'Svatojánské ořechy (St. John\'s walnuts)',
          'Jahodová marmeláda s červeným pepřem (strawberry jam, red pepper)',
          'Naše semínkové krekry (seed crackers)'
        ]
      },
      {
        id: 'syr_francie',
        name: 'Sýry z Francie',
        meta: 'pro 2 osoby | 150g',
        ingredients: [
          'Comté',
          'Brillat savarin AOP',
          'Pečené ořechy (roasted nuts)',
          'Jahodová marmeláda s červeným pepřem (strawberry jam, red pepper)',
          'Naše semínkové krekry (seed crackers)'
        ]
      },
      {
        id: 'syr_plisn',
        name: 'Plísňový kravský sýr v popelu',
        meta: '50g',
        ingredients: [
          'Svatojánské ořechy (St. John\'s walnuts)',
          'Jahodová marmeláda s červeným pepřem (strawberry jam, red pepper)',
          'Naše semínkové krekry (seed crackers)'
        ]
      },
      {
        id: 'syr_brillat',
        name: 'Brillat savarin AOP',
        meta: '50g',
        ingredients: [
          'Pečené ořechy (roasted nuts)',
          'Jahodová marmeláda s červeným pepřem (strawberry jam, red pepper)',
          'Naše semínkové krekry (seed crackers)'
        ]
      }
    ]
  },
  {
    section: 'Dezert · Dessert',
    dishes: [
      {
        id: 'kaiserschmarrn',
        name: 'Císařský trhanec „Kaiserschmarrn"',
        meta: 'dezert',
        ingredients: [
          'Jahodová omáčka s bezinkou (strawberry & elderflower sauce)',
          'Třešňovice (cherries in syrup)',
          'Mandle (almonds)',
          'Vanilková zakysaná smetana (vanilla sour cream)',
          'Cukr (sugar)',
          'Moučkový cukr (icing sugar)',
          'Přepuštěné máslo (clarified butter)'
        ]
      }
    ]
  },
  {
    section: 'Burger',
    dishes: [
      {
        id: 'burger',
        name: 'Burger',
        meta: 'hlavní chod / main',
        ingredients: [
          'Lanýžová majonéza (truffle mayo)',
          'Foie gras'
        ]
      }
    ]
  },
  {
    section: 'Dekorace & bylinky · Garnish & herbs',
    dishes: [
      {
        id: 'byliny',
        name: 'Bylinky & dekorace',
        meta: 'garnish',
        ingredients: [
          'Kerblík (chervil)',
          'Pažitka (chives)',
          'Vyšlehané máslo (whipped butter)'
        ]
      }
    ]
  },
  {
    section: 'Vybavení sekce · Equipment',
    dishes: [
      {
        id: 'vybaveni',
        name: 'Nádobí & vybavení',
        meta: 'equipment check',
        ingredients: [
          'Pánve (pans)',
          'Hrnec (pot)',
          'Gastro nádoby (gastro containers)',
          'Lžíce (spoons)',
          'Mísy (mixing bowls)',
          'Tvořítka (molds / ring cutters)'
        ]
      }
    ]
  }
];

const state = {};
menu.forEach(sec => {
  sec.dishes.forEach(d => {
    state[d.id] = { checked: {}, comment: '', open: false };
    d.ingredients.forEach((_, i) => { state[d.id].checked[i] = false; });
  });
});

function allDishes() { return menu.flatMap(s => s.dishes); }

function getProgress(dishId, total) {
  const n = Object.values(state[dishId].checked).filter(Boolean).length;
  return { n, pct: total === 0 ? 0 : Math.round((n / total) * 100) };
}

function updateGlobalStats() {
  let total = 0, done = 0;
  allDishes().forEach(d => {
    total += d.ingredients.length;
    done += Object.values(state[d.id].checked).filter(Boolean).length;
  });
  document.getElementById('global-stats').textContent = done + ' / ' + total + ' ingrediencí (ingredients)';
}

function updateTimestamp() {
  const now = new Date();
  document.getElementById('timestamp').textContent =
    'Aktualizováno (Updated): ' + now.toLocaleTimeString('cs-CZ', {hour:'2-digit', minute:'2-digit'}) +
    ' · ' + now.toLocaleDateString('cs-CZ', {day:'2-digit', month:'2-digit', year:'numeric'});
}

function resetAll() {
  allDishes().forEach(d => {
    d.ingredients.forEach((_, i) => { state[d.id].checked[i] = false; });
    state[d.id].comment = '';
  });
  render();
}

function render() {
  const app = document.getElementById('app');
  app.innerHTML = '';

  menu.forEach(sec => {
    const label = document.createElement('div');
    label.className = 'section-label';
    label.textContent = sec.section;
    app.appendChild(label);

    sec.dishes.forEach(dish => {
      const total = dish.ingredients.length;
      const { n, pct } = getProgress(dish.id, total);
      const isOpen = state[dish.id].open;
      const allDone = n === total;

      const card = document.createElement('div');
      card.className = 'card' + (isOpen ? ' open' : '') + (allDone ? ' complete' : '');

      const header = document.createElement('div');
      header.className = 'card-header';
      header.onclick = () => { state[dish.id].open = !state[dish.id].open; render(); };

      const left = document.createElement('div');
      left.className = 'card-header-left';
      left.innerHTML = '<div class="dish-name">' + dish.name + '</div><div class="dish-meta">' + dish.meta + '</div>';

      const right = document.createElement('div');
      right.className = 'card-header-right';

      const pill = document.createElement('div');
      pill.className = 'progress-pill' + (allDone ? ' done-all' : '');
      pill.textContent = n + '/' + total;

      const chevron = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      chevron.setAttribute('class', 'chevron');
      chevron.setAttribute('viewBox', '0 0 16 16');
      chevron.setAttribute('fill', 'none');
      chevron.innerHTML = '<path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>';

      right.appendChild(pill);
      right.appendChild(chevron);
      header.appendChild(left);
      header.appendChild(right);
      card.appendChild(header);

      const bar = document.createElement('div');
      bar.className = 'progress-bar';
      const fill = document.createElement('div');
      fill.className = 'progress-fill';
      fill.style.width = pct + '%';
      bar.appendChild(fill);
      card.appendChild(bar);

      const body = document.createElement('div');
      body.className = 'card-body';

      const ingList = document.createElement('div');
      ingList.className = 'ingredients';

      dish.ingredients.forEach(function(ing, i) {
        const row = document.createElement('div');
        row.className = 'ing-row';

        const box = document.createElement('div');
        box.className = 'checkbox' + (state[dish.id].checked[i] ? ' checked' : '');

        const lbl = document.createElement('span');
        lbl.className = 'ing-label' + (state[dish.id].checked[i] ? ' done' : '');
        const match = ing.match(/^(.+?)\s*\((.+)\)$/);
        if (match) {
          lbl.innerHTML = match[1] + ' <span class="ing-en">(' + match[2] + ')</span>';
        } else {
          lbl.textContent = ing;
        }

        const toggle = function(e) {
          e.stopPropagation();
          state[dish.id].checked[i] = !state[dish.id].checked[i];
          render();
        };
        box.onclick = toggle;
        lbl.onclick = toggle;

        row.appendChild(box);
        row.appendChild(lbl);
        ingList.appendChild(row);
      });

      body.appendChild(ingList);

      const footer = document.createElement('div');
      footer.className = 'footer-row';

      const ta = document.createElement('textarea');
      ta.className = 'comment-input';
      ta.placeholder = 'Poznámka (nechybí, náhrada…) · Note (missing, substitute…)';
      ta.rows = 1;
      ta.value = state[dish.id].comment;
      ta.oninput = function(e) {
        e.stopPropagation();
        state[dish.id].comment = e.target.value;
        e.target.style.height = 'auto';
        e.target.style.height = e.target.scrollHeight + 'px';
        updateTimestamp();
      };
      ta.onclick = function(e) { e.stopPropagation(); };

      const resetBtn = document.createElement('button');
      resetBtn.className = 'reset-btn';
      resetBtn.textContent = 'Reset';
      resetBtn.onclick = function(e) {
        e.stopPropagation();
        dish.ingredients.forEach(function(_, i) { state[dish.id].checked[i] = false; });
        state[dish.id].comment = '';
        render();
      };

      footer.appendChild(ta);
      footer.appendChild(resetBtn);
      body.appendChild(footer);
      card.appendChild(body);
      app.appendChild(card);
    });
  });

  updateGlobalStats();
  updateTimestamp();
}

render();
</script>
</body>
</html>
